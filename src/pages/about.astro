---
import Skill from "../components/Skill.astro";
import Nav from "../components/Nav.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="About">
  <Nav />
  <div class="main-content">
    <div class="left-column">
      <Skill
        icon="proicons:code"
        title="Frontend Development"
        iconBackground="#cdd4b1"
      />
      <Skill
        icon="proicons:computer"
        title="Web Development"
        iconBackground="#D5BB95"
        style="margin-top: 2rem;"
      />
      <Skill
        icon="proicons:phone"
        title="Mobile App Development"
        iconBackground="#DCA278"
        style="margin-top: 2rem;"
      />
    </div>

    <div class="right-column">
      <h1>About Me</h1>
      <p>
        I've spent the last few years working as a Front end Developer, building
        websites and products that are intuitive, accessible, and enjoyable to
        use. What I enjoy most is bringing designs to life and thinking about
        the people on the other side of the screen. Accessibility is something I
        care deeply about, and I try to consider it throughout the development
        process rather than treating it as an afterthought. I'm also interested
        in the bigger picture of a product: how it supports user needs, how it
        reflects the product I'm building.
      </p>
    </div>
  </div>
</Layout>

<style>
  .main-content {
    display: flex;
    flex-direction: row;
    height: calc(100vh - 50px);
  }

  .left-column {
    display: flex;
    flex: 1;
    flex-direction: column;
    text-align: center;
    align-items: center;
    justify-content: center;
  }

  .right-column {
    display: flex;
    flex: 1;
    flex-direction: column;
    text-align: center;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 450px) {
    .main-content {
      flex-direction: column-reverse;
      height: auto;
    }

    .left-column,
    .right-column {
      flex: none;
      width: 100%;
    }
    .left-column {
      margin-bottom: 2rem;
      margin-top: 2rem;
    }
    .skill {
      min-width: 100%;
    }
  }
</style>
