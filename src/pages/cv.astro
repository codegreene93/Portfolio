<style>
  * {
    box-sizing: border-box;
  }
  @page {
    size: A4;
    margin: 15mm 15mm;
    background-color: #ffffff;
    @bottom-right {
      content: "Page " counter(page) " of " counter(pages);
      font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
      font-size: 8pt;
      color: #718096;
    }
  }
  body {
    margin: 0;
    padding: 8px;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    color: #2d3748;
    line-height: 1.5;
    font-size: 10pt;
  }
  .header {
    margin-bottom: 20px;
    border-bottom: 2px solid #2b6cb0;
    padding-bottom: 15px;
  }

    .download-btn {
      background-color: #dca278;
      color: #2e2118;
      border: none;
      padding: 12px 24px;
      font-size: 1rem;
      cursor: pointer;
      border-radius: 4px;
      transition: background-color 0.2s ease-in-out;
      border-radius: 32px;
      text-decoration: none;
    }

    .download-btn:hover {
      background-color: #2a2218;
      color: #fff9e2;
    }

  .name {
    font-size: 24pt;
    font-weight: bold;
    color: #1a365d;
    margin: 0 0 5px 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .title {
    font-size: 13pt;
    font-weight: 600;
    color: #2b6cb0;
    margin: 0 0 15px 0;
  }
  .contact-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 5px;
  }
  .contact-table td {
    padding: 2px 0;
    font-size: 9pt;
    color: #4a5568;
    vertical-align: top;
  }
  .section-title {
    font-size: 13pt;
    font-weight: bold;
    color: #1a365d;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 20px 0 10px 0;
    padding-bottom: 4px;
    border-bottom: 1px solid #e2e8f0;
    page-break-after: avoid;
  }
  .profile-text {
    margin-bottom: 15px;
    text-align: justify;
  }
  .job-block {
    margin-bottom: 15px;
    page-break-inside: avoid;
  }
  .job-header-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 5px;
  }
  .job-title {
    font-size: 11pt;
    font-weight: bold;
    color: #2d3748;
    text-align: left;
  }
  .job-date {
    font-size: 10pt;
    font-weight: 600;
    color: #4a5568;
    text-align: right;
    width: 150px;
  }
  .company-name {
    font-size: 10pt;
    font-weight: 600;
    color: #2b6cb0;
    margin-bottom: 5px;
  }
  .job-desc {
    font-size: 9.5pt;
    color: #4a5568;
    margin-bottom: 6px;
    font-style: italic;
  }
  ul.bullet-list {
    margin: 0 0 10px 0;
    padding-left: 15px;
  }
  ul.bullet-list li {
    margin-bottom: 4px;
    font-size: 9.5pt;
    color: #2d3748;
  }
  .tech-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 5px;
  }
  .tech-table td {
    padding: 4px 0;
    vertical-align: top;
    font-size: 9.5pt;
  }
  .tech-label {
    font-weight: bold;
    color: #2d3748;
    width: 220px;
  }
  .tech-value {
    color: #4a5568;
  }
  .edu-block {
    margin-bottom: 12px;
    page-break-inside: avoid;
  }
  .edu-title {
    font-size: 11pt;
    font-weight: bold;
    color: #2d3748;
  }
  .edu-date {
    font-size: 10pt;
    font-weight: 600;
    color: #4a5568;
    text-align: right;
    width: 120px;
  }
  .edu-details {
    font-size: 9.5pt;
    color: #4a5568;
    margin-top: 2px;
  }
  .references {
    font-style: italic;
    color: #718096;
    margin-top: 20px;
    font-size: 9.5pt;
  }
</style>
