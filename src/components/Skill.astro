---
import { Icon } from "astro-icon/components";

const { icon, title, iconBackground = "#cdd4b1", style } = Astro.props;
---

<div class="skill" style={style}>
  <div class="icon-container" style={`background-color: ${iconBackground};`}>
    <Icon class="icon" name={icon} />
  </div>
  <h3>{title}</h3>
  <slot />
</div>

