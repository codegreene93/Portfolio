<style>
  .skill {
    display: flex;
    flex-direction: row;
    background-color: #feecd0;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 20px;
    text-align: center;
    transition: transform 0.2s ease-in-out;
    width: 40vw;
  }

  .skill:hover {
    transform: translateY(-5px);
  }

  .skill h3 {
    flex: 1;
    text-align: center;
    font-size: 1.2rem;
    align-self: center;
    color: #333;
  }
  .icon-container {
    padding: 12px;
    border-radius: 100%;
  }
  .icon {
    font-size: 2rem;
    color: #fff;
  }
</style>
